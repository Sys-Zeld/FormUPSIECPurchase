<!doctype html>
<html lang="<%= lang === 'pt' ? 'pt-BR' : 'en' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %> | <%= t("app.titleSuffix") %></title>
    <script>
      (function () {
        var storedTheme = null;
        try {
          storedTheme = localStorage.getItem("app_theme");
        } catch (_err) {
          storedTheme = null;
        }
        var theme = storedTheme === "vextrom" ? "vextrom" : "soft";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/public/css/app.css" rel="stylesheet" />
  </head>
  <body class="app-shell">
    <main class="container app-main py-4 py-md-5">
      <div class="app-topbar">
        <div class="topbar-group">
          <span class="lang-label"><%= t("head.langLabel") %>:</span>
          <a class="btn btn-sm lang-btn <%= lang === 'pt' ? 'btn-primary' : 'btn-outline-primary' %>" href="<%= currentPath %>?lang=pt">PT</a>
          <a class="btn btn-sm lang-btn <%= lang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>" href="<%= currentPath %>?lang=en">EN</a>
        </div>
        <div class="topbar-group">
          <label class="lang-label mb-0" for="themeSelector"><%= t("head.themeLabel") %>:</label>
          <select id="themeSelector" class="form-select form-select-sm theme-select" aria-label="<%= t('head.themeLabel') %>">
            <option value="soft"><%= t("head.themeSoft") %></option>
            <option value="vextrom"><%= t("head.themeVextrom") %></option>
          </select>
        </div>
      </div>
