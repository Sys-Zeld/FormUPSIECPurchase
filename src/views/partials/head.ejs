<!doctype html>
<html lang="<%= lang === 'pt' ? 'pt-BR' : 'en' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %> | <%= t("app.titleSuffix") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/public/css/app.css" rel="stylesheet" />
  </head>
  <body class="app-shell">
    <main class="container app-main py-4 py-md-5">
      <div class="app-topbar">
        <span class="lang-label"><%= t("head.langLabel") %>:</span>
        <a class="btn btn-sm lang-btn <%= lang === 'pt' ? 'btn-primary' : 'btn-outline-primary' %>" href="<%= currentPath %>?lang=pt">PT</a>
        <a class="btn btn-sm lang-btn <%= lang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>" href="<%= currentPath %>?lang=en">EN</a>
      </div>
