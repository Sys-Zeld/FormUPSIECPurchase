<%- include("partials/head", { pageTitle }) %>

<div class="card app-card mb-4">
  <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
    <div>
      <h1 class="h4 app-card-title mb-1"><%= t("admin.newClientTitle") %></h1>
      <p class="text-muted mb-0"><%= t("admin.newClientSubtitle") %></p>
    </div>
    <a class="btn btn-outline-secondary btn-sm" href="/admin/tokens"><%= t("admin.backToTokensButton") %></a>
  </div>
</div>

<div class="card app-card">
  <div class="card-body">
    <form method="post" action="/admin/clients/new" class="row g-3 needs-validation" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <% if (errors.generic) { %>
        <div class="col-12">
          <div class="alert alert-danger mb-0"><%= errors.generic %></div>
        </div>
      <% } %>

      <div class="col-12">
        <label for="purchaser" class="form-label"><%= t("admin.clientNameLabel") %></label>
        <input
          id="purchaser"
          name="purchaser"
          type="text"
          class="form-control <%= errors.purchaser ? 'is-invalid' : '' %>"
          value="<%= values.purchaser %>"
          required
        />
        <% if (errors.purchaser) { %><div class="invalid-feedback d-block"><%= errors.purchaser %></div><% } %>
      </div>

      <div class="col-12">
        <label for="purchaser_contact" class="form-label"><%= t("admin.clientContactLabel") %></label>
        <input
          id="purchaser_contact"
          name="purchaser_contact"
          type="text"
          class="form-control <%= errors.purchaser_contact ? 'is-invalid' : '' %>"
          value="<%= values.purchaser_contact %>"
          required
        />
        <% if (errors.purchaser_contact) { %><div class="invalid-feedback d-block"><%= errors.purchaser_contact %></div><% } %>
      </div>

      <div class="col-12">
        <label for="profile_id" class="form-label"><%= t("admin.profileSelectLabel") %></label>
        <select id="profile_id" name="profile_id" class="form-select <%= errors.profile_id ? 'is-invalid' : '' %>">
          <option value=""><%= t("admin.profileManualOption") %></option>
          <% profiles.forEach((profile) => { %>
            <option value="<%= profile.id %>" <%= String(values.profile_id || '') === String(profile.id) ? 'selected' : '' %>>
              <%= profile.name %> (<%= profile.fieldsCount %>)
            </option>
          <% }) %>
        </select>
        <% if (errors.profile_id) { %><div class="invalid-feedback d-block"><%= errors.profile_id %></div><% } %>
      </div>

      <div class="col-12">
        <label for="profile_name" class="form-label"><%= t("admin.profileSaveAsLabel") %></label>
        <input
          id="profile_name"
          name="profile_name"
          type="text"
          class="form-control <%= errors.name ? 'is-invalid' : '' %>"
          value="<%= values.profile_name || '' %>"
          placeholder="<%= t('admin.profileSaveAsPlaceholder') %>"
        />
        <% if (errors.name) { %><div class="invalid-feedback d-block"><%= errors.name %></div><% } %>
      </div>

      <div class="col-12">
        <div class="d-flex gap-2 flex-wrap">
          <button class="btn btn-outline-primary btn-sm" type="button" data-toggle-fields="all"><%= t("admin.enableAll") %></button>
          <button class="btn btn-outline-secondary btn-sm" type="button" data-toggle-fields="none"><%= t("admin.disableAll") %></button>
        </div>
      </div>

      <div class="col-12">
        <label class="form-label"><%= t("admin.clientFieldsLabel") %></label>
        <% if (errors.enabled_fields) { %><div class="text-danger small mb-2"><%= errors.enabled_fields %></div><% } %>
        <div class="accordion" id="fieldsAccordion">
          <% sections.forEach((section, idx) => { %>
            <div class="accordion-item app-accordion-item mb-2 border rounded-3">
              <h2 class="accordion-header" id="heading_<%= idx %>">
                <button class="accordion-button <%= idx > 0 ? 'collapsed' : '' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_<%= idx %>">
                  <%= section.name %> (<%= section.fields.length %>)
                </button>
              </h2>
              <div id="collapse_<%= idx %>" class="accordion-collapse collapse <%= idx === 0 ? 'show' : '' %>" data-bs-parent="#fieldsAccordion">
                <div class="accordion-body">
                  <div class="row g-2">
                    <% section.fields.forEach((field) => { %>
                      <div class="col-12 col-md-6">
                        <div class="form-check">
                          <input
                            class="form-check-input field-checkbox"
                            type="checkbox"
                            id="enabled_field_<%= field.id %>"
                            name="enabled_fields"
                            value="<%= field.id %>"
                            <%= selectedFieldIds.includes(field.id) ? 'checked' : '' %>
                          />
                          <label class="form-check-label" for="enabled_field_<%= field.id %>">
                            <%= field.label %> <span class="text-muted">(<code><%= field.key %></code>)</span>
                          </label>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="col-12 actions-row">
        <button class="btn btn-primary ms-auto" type="submit"><%= t("admin.generateTokenAndGoButton") %></button>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const profileFieldMap = <%- JSON.stringify(profileFieldMap || {}) %>;
    const profileSelect = document.getElementById("profile_id");
    const fieldCheckboxes = Array.from(document.querySelectorAll(".field-checkbox"));
    const toggleButtons = document.querySelectorAll("[data-toggle-fields]");

    function setAll(checked) {
      fieldCheckboxes.forEach((checkbox) => {
        checkbox.checked = checked;
      });
    }

    toggleButtons.forEach((button) => {
      button.addEventListener("click", function () {
        setAll(button.dataset.toggleFields === "all");
      });
    });

    if (profileSelect) {
      profileSelect.addEventListener("change", function () {
        const profileId = String(profileSelect.value || "");
        if (!profileId || !profileFieldMap[profileId]) return;
        const enabled = new Set((profileFieldMap[profileId] || []).map(String));
        fieldCheckboxes.forEach((checkbox) => {
          checkbox.checked = enabled.has(String(checkbox.value));
        });
      });
    }
  })();
</script>

<%- include("partials/footer") %>
