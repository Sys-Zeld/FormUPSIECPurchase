<%- include("partials/head", { pageTitle }) %>

<div class="card app-card mb-4">
  <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
    <div>
      <h1 class="h4 app-card-title mb-1"><%= t("admin.pageTitle") %></h1>
      <p class="text-muted mb-0"><%= t("admin.pageSubtitle") %></p>
    </div>
    <form method="post" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t("admin.logoutButton") %></button>
    </form>
  </div>
</div>

<% if (deleted) { %>
  <div class="alert alert-success"><%= t("admin.deletedSuccess") %></div>
<% } %>

<div class="card app-card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0 app-table">
        <thead>
          <tr>
            <th><%= t("admin.tableToken") %></th>
            <th><%= t("admin.tableBuyer") %></th>
            <th><%= t("admin.tableContact") %></th>
            <th><%= t("admin.tableStatus") %></th>
            <th><%= t("admin.tableUpdatedAt") %></th>
            <th><%= t("admin.tableActions") %></th>
          </tr>
        </thead>
        <tbody>
          <% if (!rows.length) { %>
            <tr>
              <td colspan="6" class="text-center text-muted py-4"><%= t("admin.noRecords") %></td>
            </tr>
          <% } %>
          <% rows.forEach((row) => { %>
            <tr>
              <td>
                <code class="token-code"><%= row.token %></code>
              </td>
              <td><%= row.purchaser || "-" %></td>
              <td><%= row.purchaser_contact || "-" %></td>
              <td><span class="badge text-bg-light border"><%= row.status %></span></td>
              <td><%= row.updated_at ? new Date(row.updated_at).toLocaleString(lang === "pt" ? "pt-BR" : "en-US") : "-" %></td>
              <td>
                <div class="d-flex gap-2 flex-wrap">
                  <a class="btn btn-outline-primary btn-sm" href="/form/<%= row.token %>/review"><%= t("admin.viewButton") %></a>
                  <form method="post" action="/admin/tokens/<%= row.id %>/delete" onsubmit="return confirm('<%= t("admin.confirmDelete") %>')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="btn btn-outline-danger btn-sm" type="submit"><%= t("admin.deleteButton") %></button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
