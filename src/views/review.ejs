<%- include("partials/head", { pageTitle }) %>

<div class="card app-card mb-4">
  <div class="card-body d-flex justify-content-between align-items-start flex-wrap gap-3">
    <div>
      <h1 class="h4 app-card-title mb-1"><%= t("review.headerTitle") %></h1>
      <p class="text-muted mb-0">Token: <code class="token-code"><%= equipment.token %></code></p>
    </div>
    <div class="d-flex flex-column align-items-end gap-2">
      <img class="header-qr" src="<%= qrDataUrl %>" alt="QR do link da submissao" />
      <div class="d-flex gap-2 flex-wrap justify-content-end">
        <a class="btn btn-outline-secondary btn-sm" href="/form/<%= equipment.token %>/specification"><%= t("review.backToForm") %></a>
        <a class="btn btn-outline-primary btn-sm" href="/form/<%= equipment.token %>/export.json"><%= t("review.exportJson") %></a>
        <a class="btn btn-primary btn-sm" href="/form/<%= equipment.token %>/pdf"><%= t("review.downloadPdf") %></a>
      </div>
    </div>
  </div>
</div>

<% if (emailSent) { %>
  <div class="alert alert-success"><%= t("review.emailSent") %></div>
<% } %>

<% sections.forEach((section) => { %>
  <div class="card app-card mb-3">
    <div class="card-body">
      <h2 class="h6 app-card-title"><%= section.section %></h2>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0 app-table">
          <thead>
            <tr>
              <th><%= t("review.tableField") %></th>
              <th><%= t("review.tableValue") %></th>
              <th><%= t("review.tableUnit") %></th>
            </tr>
          </thead>
          <tbody>
            <% section.fields.forEach((field) => { %>
              <tr>
                <td><%= field.label %></td>
                <td>
                  <%= (field.displayValue !== "" && field.displayValue !== null && field.displayValue !== undefined) ? field.displayValue : "-" %>
                  <% if (field.cameFromDefault) { %><span class="app-default-badge ms-1"><%= t("field.defaultBadge") %></span><% } %>
                </td>
                <td><%= field.unit || "-" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% }) %>

<div class="card app-card mb-3">
  <div class="card-body">
    <h2 class="h6 app-card-title"><%= t("review.documentsTitle") %></h2>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0 app-table">
        <thead>
          <tr>
            <th>Arquivo</th>
            <th>Tamanho</th>
            <th>Acesso</th>
          </tr>
        </thead>
        <tbody>
          <% if (!documents || !documents.length) { %>
            <tr><td colspan="3" class="text-muted"><%= t("section.documentsNone") %></td></tr>
          <% } %>
          <% (documents || []).forEach((doc) => { %>
            <tr>
              <td><%= doc.originalName %></td>
              <td><%= (doc.sizeBytes / (1024 * 1024)).toFixed(2) %> MB</td>
              <td><a class="btn btn-sm btn-outline-secondary" href="<%= doc.externalUrl %>" target="_blank" rel="noreferrer"><%= t("section.documentsOpen") %></a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="card app-card">
  <div class="card-body">
    <h2 class="h6 app-card-title"><%= t("review.sendByEmail") %></h2>
    <form method="post" action="/form/<%= equipment.token %>/send-email" class="row g-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="col-md-8">
        <label for="to" class="form-label"><%= t("review.recipient") %></label>
        <input id="to" name="to" class="form-control" type="email" required placeholder="cliente@empresa.com" />
      </div>
      <div class="col-md-4 d-grid align-items-end">
        <button class="btn btn-success mt-md-4" type="submit"><%= t("review.sendEmailPdf") %></button>
      </div>
    </form>
  </div>
</div>

<%- include("partials/footer") %>
