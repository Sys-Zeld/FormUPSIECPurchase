<%- include("partials/head", { pageTitle }) %>

<div class="card app-card mb-4">
  <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
    <div>
      <h1 class="h4 app-card-title mb-1"><%= t("admin.fieldsTitle") %></h1>
      <p class="text-muted mb-0"><%= t("admin.fieldsSubtitle") %></p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-outline-secondary btn-sm" href="/admin/tokens"><%= t("admin.backToTokensButton") %></a>
      <form method="post" action="/admin/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t("admin.logoutButton") %></button>
      </form>
    </div>
  </div>
</div>

<% if (saved) { %>
  <div class="alert alert-success"><%= t("admin.fieldsSaved") %></div>
<% } %>

<form method="post" action="/admin/fields">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

  <div class="actions-row mb-3">
    <button class="btn btn-outline-primary btn-sm" type="button" data-toggle-all="on"><%= t("admin.enableAll") %></button>
    <button class="btn btn-outline-secondary btn-sm" type="button" data-toggle-all="off"><%= t("admin.disableAll") %></button>
    <button class="btn btn-primary btn-sm ms-auto" type="submit"><%= t("admin.saveFieldsButton") %></button>
  </div>

  <% sections.forEach((section) => { %>
    <div class="card app-card mb-3">
      <div class="card-body">
        <h2 class="h6 app-card-title mb-1"><%= section.title %></h2>
        <% if (section.description) { %>
          <p class="text-muted mb-3"><%= section.description %></p>
        <% } %>
        <div class="row g-2">
          <% section.fields.forEach((field) => { %>
            <div class="col-12 col-md-6">
              <div class="form-check border rounded-3 p-2 bg-light-subtle">
                <input
                  class="form-check-input admin-field-checkbox"
                  type="checkbox"
                  name="enabled_fields"
                  value="<%= field.id %>"
                  id="field_<%= field.id %>"
                  <%= field.enabled ? "checked" : "" %>
                />
                <label class="form-check-label w-100" for="field_<%= field.id %>">
                  <span class="fw-semibold"><%= field.label %></span>
                  <span class="d-block text-muted small"><code><%= field.id %></code></span>
                </label>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  <% }) %>

  <div class="actions-row">
    <button class="btn btn-primary ms-auto" type="submit"><%= t("admin.saveFieldsButton") %></button>
  </div>
</form>

<script>
  (function () {
    const checkboxes = Array.from(document.querySelectorAll(".admin-field-checkbox"));
    const allOn = document.querySelector('[data-toggle-all="on"]');
    const allOff = document.querySelector('[data-toggle-all="off"]');

    if (allOn) {
      allOn.addEventListener("click", function () {
        checkboxes.forEach(function (el) { el.checked = true; });
      });
    }
    if (allOff) {
      allOff.addEventListener("click", function () {
        checkboxes.forEach(function (el) { el.checked = false; });
      });
    }
  })();
</script>

<%- include("partials/footer") %>
